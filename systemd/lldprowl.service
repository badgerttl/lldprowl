[Unit]
Description=LLDProwl LLDP Tester Web App
After=network.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/LLDProwl
ExecStart=/home/pi/LLDProwl/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

# If not using capabilities on Python, use root for raw capture:
# User=root
# ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000

[Install]
WantedBy=multi-user.target
